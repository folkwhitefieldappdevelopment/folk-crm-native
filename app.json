{
  "expo": {
    "name": "FOLK Spiritual Gems",
    "slug": "folk-spiritual-gems",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#3F51B5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3F51B5"
      },
      "package": "com.folkcrm.gems",
      "permissions": [
        "READ_CALL_LOG",
        "READ_CONTACTS"
      ]
    },
    "cli": {
      "appVersionSource": "remote"
    },
    "owner": "folk_whitefield",
    "extra": {
      "eas": {
        "projectId": "fc588c02-79af-45ca-bcd5-1a060faaad0b"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "expo-asset",
      "expo-notifications",
      "expo-font"
    ]
  }
}
